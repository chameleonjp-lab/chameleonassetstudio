{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://chameleonjp-lab.github.io/chameleonassetstudio/schema/project.schema.json",
  "title": "Chameleon Project",
  "description": "1 つ以上のアセットをまとめる作業単位（project.json）。",
  "type": "object",
  "required": ["format", "version", "id", "name", "assets", "createdAt", "updatedAt"],
  "properties": {
    "format": { "const": "chameleon-project" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "assetType"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "displayName": { "type": "string" },
          "assetType": {
            "enum": ["character", "item", "background", "tile", "gimmick", "effect"]
          }
        }
      }
    },
    "families": {
      "type": "array",
      "items": { "$ref": "#/definitions/assetFamily" }
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "definitions": {
    "idList": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "relativePathList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(?!/)(?!.*\\\\)(?!.*//)(?!.*\\/$)(?!\\.{1,2}(?:/|$))(?!.*/\\.{1,2}(?:/|$))[^\\u0000-\\u001F\\u007F-\\u009F]+$"
      },
      "uniqueItems": true
    },
    "idMapRecord": {
      "type": "object",
      "propertyNames": { "type": "string", "minLength": 1 },
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "familyVariantIdMap": {
      "type": "object",
      "required": ["textures", "layers", "parts", "anchors", "colliders", "frames", "animations"],
      "properties": {
        "textures": { "$ref": "#/definitions/idMapRecord" },
        "layers": { "$ref": "#/definitions/idMapRecord" },
        "parts": { "$ref": "#/definitions/idMapRecord" },
        "anchors": { "$ref": "#/definitions/idMapRecord" },
        "colliders": { "$ref": "#/definitions/idMapRecord" },
        "frames": { "$ref": "#/definitions/idMapRecord" },
        "animations": { "$ref": "#/definitions/idMapRecord" }
      }
    },
    "familyVariantWriteSet": {
      "type": "object",
      "required": [
        "textures",
        "layers",
        "parts",
        "anchors",
        "colliders",
        "frames",
        "animations",
        "blobPaths"
      ],
      "properties": {
        "textures": { "$ref": "#/definitions/idList" },
        "layers": { "$ref": "#/definitions/idList" },
        "parts": { "$ref": "#/definitions/idList" },
        "anchors": { "$ref": "#/definitions/idList" },
        "colliders": { "$ref": "#/definitions/idList" },
        "frames": { "$ref": "#/definitions/idList" },
        "animations": { "$ref": "#/definitions/idList" },
        "blobPaths": { "$ref": "#/definitions/relativePathList" }
      }
    },
    "paletteReplacement": {
      "type": "object",
      "required": ["from", "to"],
      "properties": {
        "from": { "type": "string", "pattern": "^#([0-9a-fA-F]{6}|[0-9a-fA-F]{8})$" },
        "to": { "type": "string", "pattern": "^#([0-9a-fA-F]{6}|[0-9a-fA-F]{8})$" }
      }
    },
    "mirrorFamilyVariantRecipe": {
      "type": "object",
      "required": ["type", "idMap", "writeSet"],
      "properties": {
        "type": { "const": "mirror" },
        "idMap": { "$ref": "#/definitions/familyVariantIdMap" },
        "writeSet": { "$ref": "#/definitions/familyVariantWriteSet" }
      },
      "not": {
        "anyOf": [
          { "required": ["baseLayerIds"] },
          { "required": ["replacements"] },
          { "required": ["tolerance"] }
        ]
      }
    },
    "paletteFamilyVariantRecipe": {
      "type": "object",
      "required": ["type", "idMap", "baseLayerIds", "writeSet", "replacements", "tolerance"],
      "properties": {
        "type": { "const": "palette" },
        "idMap": { "$ref": "#/definitions/familyVariantIdMap" },
        "baseLayerIds": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        },
        "writeSet": { "$ref": "#/definitions/familyVariantWriteSet" },
        "replacements": {
          "type": "array",
          "items": { "$ref": "#/definitions/paletteReplacement" },
          "minItems": 1
        },
        "tolerance": { "type": "number", "minimum": 0, "maximum": 255 }
      }
    },
    "familyVariantFingerprint": {
      "type": "object",
      "required": ["base", "variant", "syncedAt"],
      "properties": {
        "base": { "type": "string", "minLength": 1 },
        "variant": { "type": "string", "minLength": 1 },
        "syncedAt": { "type": "string", "format": "date-time" }
      }
    },
    "linkedMirrorAssetFamilyVariant": {
      "type": "object",
      "required": ["assetId", "kind", "recipe", "fingerprint"],
      "properties": {
        "assetId": { "type": "string", "minLength": 1 },
        "kind": { "const": "linked-mirror" },
        "recipe": { "$ref": "#/definitions/mirrorFamilyVariantRecipe" },
        "fingerprint": { "$ref": "#/definitions/familyVariantFingerprint" }
      }
    },
    "linkedPaletteAssetFamilyVariant": {
      "type": "object",
      "required": ["assetId", "kind", "recipe", "fingerprint"],
      "properties": {
        "assetId": { "type": "string", "minLength": 1 },
        "kind": { "const": "linked-palette" },
        "recipe": { "$ref": "#/definitions/paletteFamilyVariantRecipe" },
        "fingerprint": { "$ref": "#/definitions/familyVariantFingerprint" }
      }
    },
    "manualAssetFamilyVariant": {
      "type": "object",
      "required": ["assetId", "kind"],
      "properties": {
        "assetId": { "type": "string", "minLength": 1 },
        "kind": { "const": "manual" }
      },
      "not": {
        "anyOf": [{ "required": ["recipe"] }, { "required": ["fingerprint"] }]
      }
    },
    "assetFamilyVariant": {
      "oneOf": [
        { "$ref": "#/definitions/linkedMirrorAssetFamilyVariant" },
        { "$ref": "#/definitions/linkedPaletteAssetFamilyVariant" },
        { "$ref": "#/definitions/manualAssetFamilyVariant" }
      ]
    },
    "assetFamily": {
      "type": "object",
      "required": ["id", "name", "baseAssetId", "variants"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "baseAssetId": { "type": "string", "minLength": 1 },
        "variants": {
          "type": "array",
          "items": { "$ref": "#/definitions/assetFamilyVariant" }
        }
      }
    }
  }
}
